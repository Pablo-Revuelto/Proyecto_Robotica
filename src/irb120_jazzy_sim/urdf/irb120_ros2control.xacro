<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="irb120_ros2control" params="bringup robot_ip EE EE_name prefix use_mock_hardware:=^|false" >

    <!-- 1. ROS2_CONTROL tag name: -->
    <!-- A. GAZEBO SIMULATION: -->
    <xacro:unless value="${bringup}">
      <xacro:property name="name" value="${prefix}GazeboSystem"/>
    </xacro:unless>
    <!-- B. ROBOT BRINGUP: -->
    <xacro:if value="${bringup}">
      <xacro:property name="name" value="${prefix}ABBMultiInterfaceHardware"/>
    </xacro:if>

    <!-- 3. Load ROS2_CONTROL: -->
    <ros2_control name="${name}" type="system">

      <!-- A. GAZEBO SIMULATION (o MOCK HARDWARE para demo sin Gazebo): -->
      <xacro:unless value="${bringup}">
        <xacro:if value="${use_mock_hardware}">
          <hardware>
            <plugin>mock_components/GenericSystem</plugin>
          </hardware>
        </xacro:if>
        <xacro:unless value="${use_mock_hardware}">
          <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
          </hardware>
        </xacro:unless>
      </xacro:unless>

      <!-- B. ROBOT BRINGUP: -->
      <xacro:if value="${bringup}">
        <hardware>
          <plugin>abb_hardware_interface/ABBSystemHardware</plugin>
          <param name="rws_port">80</param>
          <param name="rws_ip">${robot_ip}</param>
          <param name="egm_port">6511</param>
        </hardware>
      </xacro:if>

      <!-- irb120_joint1 -->
      <joint name="${prefix}joint_1">
        <command_interface name="position">
          <param name="min">-2.87979</param>
          <param name="max">2.87979</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <!-- irb120_joint2 -->
      <joint name="${prefix}joint_2">
        <command_interface name="position">
          <param name="min">-1.91986</param>
          <param name="max">1.91986</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <!-- irb120_joint3 -->
      <joint name="${prefix}joint_3">
        <command_interface name="position">
          <param name="min">-1.91986</param>
          <param name="max">1.22173</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <!-- irb120_joint4 -->
      <joint name="${prefix}joint_4">
        <command_interface name="position">
          <param name="min">-2.79253</param>
          <param name="max">2.79253</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <!-- irb120_joint5 -->
      <joint name="${prefix}joint_5">
        <command_interface name="position">
          <param name="min">-2.00</param>       <!-- Joint5 limits lowered to +-2rad -->
          <param name="max">2.00</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">1.570796</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <!-- irb120_joint6 -->
      <joint name="${prefix}joint_6">
        <command_interface name="position">
          <param name="min">-6.98132</param> 
          <param name="max">6.98132</param> 
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <!-- END EFFECTOR -->
      <xacro:unless value="${bringup}">
        <xacro:if value="${EE}">
          <xacro:include filename="$(find ros2srrc_endeffectors)/${EE_name}/urdf/${EE_name}_ros2control.xacro" />
          <xacro:EE_ros2control prefix="${prefix}" />
        </xacro:if>
      </xacro:unless>

    </ros2_control>

    <xacro:unless value="${bringup}">

      <gazebo>
        <plugin
          filename="gz_ros2_control-system"
          name="gz_ros2_control::GazeboSimROS2ControlPlugin">
          <parameters>$(find irb120_jazzy_sim)/config/ros2_controllers.yaml</parameters>
        </plugin>
      </gazebo>


      <gazebo reference="${prefix}base_link">
        <selfCollide>false</selfCollide>
      </gazebo>
      <gazebo reference="${prefix}link_1">
        <selfCollide>false</selfCollide>
      </gazebo>
      <gazebo reference="${prefix}link_2">
        <selfCollide>false</selfCollide>
      </gazebo>
      <gazebo reference="${prefix}link_3">
        <selfCollide>false</selfCollide>
      </gazebo>
      <gazebo reference="${prefix}link_4">
        <selfCollide>false</selfCollide>
      </gazebo>
      <gazebo reference="${prefix}link_5">
        <selfCollide>false</selfCollide>
      </gazebo>
      <gazebo reference="${prefix}link_6">
        <selfCollide>false</selfCollide>
      </gazebo>
    
      <gazebo reference="${prefix}end_effector_frame_fixed_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
        <!-- For compatibility with SDFormat < 4.4 -->
        <disableFixedJointLumping>true</disableFixedJointLumping>
      </gazebo>

    </xacro:unless>

  </xacro:macro>

</robot>
