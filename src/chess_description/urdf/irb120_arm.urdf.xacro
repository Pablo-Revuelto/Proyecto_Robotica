<?xml version="1.0"?>
<!--
ABB IRB120 link+joint macro (NO ros2_control, NO plugin) for use in the
multi-robot dual-arm chess scene. Reuses the original IRB120 meshes from the
unmodified `irb120_jazzy_sim` package.

Geometry / inertias mirror those in
  irb120_jazzy_sim/urdf/irb120_macro.urdf.xacro
(IFRA-Cranfield, ROS-Industrial, Apache-2.0).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find irb120_jazzy_sim)/urdf/abb_resources/common_materials.xacro"/>

  <xacro:macro name="irb120_arm" params="prefix">

    <link name="${prefix}base_link">
      <inertial>
        <mass value="6.215"/>
        <origin xyz="-0.04204 8.01E-05 0.07964" rpy="0 0 0"/>
        <inertia ixx="0.0247272" ixy="-8.0784E-05" ixz="0.00130902"
                 iyy="0.0491285" iyz="-8.0419E-06" izz="0.0472376"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/base_link.dae"/></geometry>
        <xacro:material_abb_orange/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/base_link.stl"/></geometry>
      </collision>
    </link>

    <link name="${prefix}link_1">
      <inertial>
        <mass value="3.067"/>
        <origin xyz="9.77E-05 -0.00012 0.23841" rpy="0 0 0"/>
        <inertia ixx="0.0142175" ixy="-1.28579E-05" ixz="-2.31364E-05"
                 iyy="0.0144041" iyz="1.93404E-05" izz="0.0104533"/>
      </inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/link_1.dae"/></geometry>
        <xacro:material_abb_orange/></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/link_1.stl"/></geometry></collision>
    </link>

    <link name="${prefix}link_2">
      <inertial>
        <mass value="3.909"/>
        <origin xyz="0.00078 -0.00212 0.10124" rpy="0 0 0"/>
        <inertia ixx="0.0603111" ixy="9.83431E-06" ixz="5.72407E-05"
                 iyy="0.041569" iyz="-0.00050497" izz="0.0259548"/>
      </inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/link_2.dae"/></geometry>
        <xacro:material_abb_orange/></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/link_2.stl"/></geometry></collision>
    </link>

    <link name="${prefix}link_3">
      <inertial>
        <mass value="2.944"/>
        <origin xyz="0.02281 0.00106 0.05791" rpy="0 0 0"/>
        <inertia ixx="0.00835606" ixy="-8.01545E-05" ixz="0.00142884"
                 iyy="0.016713" iyz="-0.000182227" izz="0.0126984"/>
      </inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/link_3.dae"/></geometry>
        <xacro:material_abb_orange/></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/link_3.stl"/></geometry></collision>
    </link>

    <link name="${prefix}link_4">
      <inertial>
        <mass value="1.328"/>
        <origin xyz="0.2247 0.00015 0.00041" rpy="0 0 0"/>
        <inertia ixx="0.00284661" ixy="-2.12765E-05" ixz="-1.6435E-05"
                 iyy="0.00401346" iyz="1.31336E-05" izz="0.0052535"/>
      </inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/link_4.dae"/></geometry>
        <xacro:material_abb_orange/></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/link_4.stl"/></geometry></collision>
    </link>

    <link name="${prefix}link_5">
      <inertial>
        <mass value="0.546"/>
        <origin xyz="-0.00109 3.68E-05 6.22E-05" rpy="0 0 0"/>
        <inertia ixx="0.000404891" ixy="1.61943E-06" ixz="8.46805E-07"
                 iyy="0.000892825" iyz="-1.51792E-08" izz="0.000815468"/>
      </inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/link_5.dae"/></geometry>
        <xacro:material_abb_orange/></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/link_5.stl"/></geometry></collision>
    </link>

    <link name="${prefix}link_6">
      <inertial>
        <mass value="0.137"/>
        <origin xyz="-0.00706 -0.00017 -1.32E-06" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/visual/link_6.dae"/></geometry>
        <xacro:material_abb_black/></visual>
      <collision><origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="file://$(find irb120_jazzy_sim)/meshes/collision/link_6.stl"/></geometry></collision>
    </link>

    <joint name="${prefix}joint_1" type="revolute">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="${prefix}base_link"/><child link="${prefix}link_1"/>
      <limit effort="1000" lower="-2.87979" upper="2.87979" velocity="4.36332"/>
      <axis xyz="0 0 1"/><dynamics damping="50.0" friction="1.0"/>
    </joint>
    <joint name="${prefix}joint_2" type="revolute">
      <origin rpy="0 0 0" xyz="0 0 0.29"/>
      <parent link="${prefix}link_1"/><child link="${prefix}link_2"/>
      <limit effort="1000" lower="-1.91986" upper="1.91986" velocity="4.36332"/>
      <axis xyz="0 1 0"/><dynamics damping="50.0" friction="1.0"/>
    </joint>
    <joint name="${prefix}joint_3" type="revolute">
      <origin rpy="0 0 0" xyz="0 0 0.27"/>
      <parent link="${prefix}link_2"/><child link="${prefix}link_3"/>
      <limit effort="1000" lower="-1.91986" upper="1.22173" velocity="4.36332"/>
      <axis xyz="0 1 0"/><dynamics damping="10.0" friction="1.0"/>
    </joint>
    <joint name="${prefix}joint_4" type="revolute">
      <origin rpy="0 0 0" xyz="0 0 0.07"/>
      <parent link="${prefix}link_3"/><child link="${prefix}link_4"/>
      <limit effort="1000" lower="-2.79253" upper="2.79253" velocity="5.58505"/>
      <axis xyz="1 0 0"/><dynamics damping="5.0" friction="1.0"/>
    </joint>
    <joint name="${prefix}joint_5" type="revolute">
      <origin rpy="0 0 0" xyz="0.302 0 0"/>
      <parent link="${prefix}link_4"/><child link="${prefix}link_5"/>
      <limit effort="1000" lower="-2.094395" upper="2.094395" velocity="5.58505"/>
      <axis xyz="0 1 0"/><dynamics damping="2.0" friction="1.0"/>
    </joint>
    <joint name="${prefix}joint_6" type="revolute">
      <origin rpy="0 0 0" xyz="0.072 0 0"/>
      <parent link="${prefix}link_5"/><child link="${prefix}link_6"/>
      <limit effort="1000" lower="-6.98132" upper="6.98132" velocity="7.33038"/>
      <axis xyz="1 0 0"/><dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="${prefix}flange"/>
    <joint name="${prefix}joint_6-flange" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}link_6"/><child link="${prefix}flange"/>
    </joint>

    <link name="${prefix}tool0"/>
    <joint name="${prefix}link_6-tool0" type="fixed">
      <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
      <parent link="${prefix}flange"/><child link="${prefix}tool0"/>
    </joint>

  </xacro:macro>

</robot>
